---
import BaseLayout from "../layouts/BaseLayout.astro";
import properties from "../data/properties.json";

const propertySlug = Astro.url.searchParams.get("inmueble");
const selectedProperty = properties.find((property) => property.slug === propertySlug);
---

<BaseLayout
	title="Contacto | d’Papeleos Asesores"
	description="Contacta con d’Papeleos Asesores en San Isidro de Níjar, Almería, para solicitar información sobre asesoría, gestoría, trámites de tráfico o inmuebles disponibles."
>
	<section class="page-hero">
		<div class="container page-hero-content">
			<p class="eyebrow">Contacto</p>
			<h1>Contacta con la asesoría y te orientaremos.</h1>
			<p>
				Utiliza el teléfono o el email para resolver dudas, solicitar información
				sobre un servicio, gestionar un trámite o consultar un inmueble
				disponible.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container contact-grid">
			<div class="contact-info">
				<p class="eyebrow">Atención personalizada</p>
				<h2>Estamos para ayudarte.</h2>

				<p>
					Contacta por teléfono o email para solicitar información sobre servicios
					de asesoría, gestoría, trámites de tráfico o inmuebles disponibles.
				</p>

				<div class="contact-details">
					<div>
						<h3>Teléfono</h3>
						<p>
							<a href="tel:+34685554865">+34 685 55 48 65</a>
						</p>
					</div>

					<div>
						<h3>Email</h3>
						<p>
							<a href="mailto:depapeleos@gmail.com">depapeleos@gmail.com</a>
						</p>
					</div>

					<div>
						<h3>Ubicación</h3>
						<p>Avenida de la Constitución 19</p>
						<p>San Isidro de Níjar, Almería</p>
					</div>

					<div>
						<h3>Horario</h3>
						<p>Lunes a viernes, de 9:30 h a 13:45 h.</p>
						<p>Tardes solo con cita previa.</p>
					</div>
				</div>
			</div>

			<form
				class="contact-form"
				aria-label="Formulario de contacto"
				aria-describedby="contact-form-status"
			>
				<p id="contact-form-status" class="form-note form-field-full">
					Para contactar ahora, utiliza el teléfono o el email indicados en esta
					página. El formulario quedará disponible cuando se active la integración.
				</p>

				{propertySlug && (
					<div class="property-form-notice form-field-full">
						<p class="eyebrow">Consulta sobre inmueble</p>

						{selectedProperty ? (
							<p>
								Has llegado desde la ficha de <strong>{selectedProperty.title}</strong>.
								Indica esta referencia al contactar por teléfono o email para que la
								asesoría pueda identificarla correctamente.
							</p>
						) : (
							<p>
								Has llegado desde una ficha de inmueble. Indica esta referencia al
								contactar por teléfono o email para que la asesoría pueda identificarla
								correctamente.
							</p>
						)}

						<input type="hidden" name="propertySlug" value={propertySlug} />
						{selectedProperty && (
							<input
								type="hidden"
								name="propertyTitle"
								value={selectedProperty.title}
							/>
						)}
					</div>
				)}
				<div class="form-field">
					<label for="name">Nombre y apellidos</label>
					<input
						id="name"
						name="name"
						type="text"
						autocomplete="name"
						disabled
						placeholder="Tu nombre"
					/>
				</div>

				<div class="form-field">
					<label for="email">Email</label>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						disabled
						placeholder="tu@email.com"
					/>
				</div>

				<div class="form-field">
					<label for="phone">Teléfono</label>
					<input
						id="phone"
						name="phone"
						type="tel"
						autocomplete="tel"
						disabled
						placeholder="Tu teléfono"
					/>
				</div>

				<div class="form-field">
					<label for="subject">Tipo de consulta</label>
					<select id="subject" name="subject" disabled>
						<option value="">Selecciona una opción</option>
						<option value="asesoria-fiscal">Asesoría fiscal</option>
						<option value="asesoria-contable">Asesoría contable</option>
						<option value="asesoria-laboral">Asesoría laboral</option>
						<option value="gestion-administrativa">Gestoría y trámites administrativos</option>
						<option value="trafico">Trámites de tráfico y vehículos</option>
						<option value="herencias-donaciones">Herencias y donaciones</option>
						<option value="inmobiliaria" selected={Boolean(propertySlug)}>Inmobiliaria</option>
						<option value="otra-consulta">Otra consulta</option>
					</select>
				</div>

				<div class="form-field form-field-full">
					<label for="message">Mensaje</label>
					<textarea
						id="message"
						name="message"
						rows="6"
						disabled
						placeholder="Formulario pendiente de activar"
					></textarea>
				</div>

				<label class="privacy-check form-field-full">
					<input type="checkbox" name="privacy" disabled />
					<span>
						Política de privacidad pendiente de revisión profesional antes de
						activar el formulario.
					</span>
				</label>

				<p class="form-note form-field-full">
					Mientras tanto, puedes contactar directamente por teléfono o email.
				</p>

				<div class="form-actions form-field-full">
					<button class="button button-primary" type="submit" disabled>
						Envío pendiente de activar
					</button>
				</div>
			</form>
		</div>
	</section>
</BaseLayout>