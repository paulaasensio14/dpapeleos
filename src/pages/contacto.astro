---
import BaseLayout from "../layouts/BaseLayout.astro";

const propertySlug = Astro.url.searchParams.get("inmueble");
---

<BaseLayout
	title="Contacto | d’Papeleos Asesores"
	description="Contacta con d’Papeleos Asesores para solicitar información sobre servicios de asesoría o inmuebles disponibles."
>
	<section class="page-hero">
		<div class="container page-hero-content">
			<p class="eyebrow">Contacto</p>
			<h1>Cuéntanos qué necesitas y te orientaremos.</h1>
			<p>
				Contacta con la asesoría para resolver dudas, solicitar información sobre
				un servicio o consultar un inmueble disponible.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container contact-grid">
			<div class="contact-info">
				<p class="eyebrow">Atención personalizada</p>
				<h2>Estamos para ayudarte.</h2>

				<p>
					Completa el formulario y nos pondremos en contacto contigo lo antes
					posible. Los datos de contacto, ubicación y horario son provisionales
					y deberán validarse con el cliente.
				</p>

				<div class="contact-details">
					<div>
						<h3>Teléfono</h3>
						<p>Pendiente de confirmar</p>
					</div>

					<div>
						<h3>Email</h3>
						<p>Pendiente de confirmar</p>
					</div>

					<div>
						<h3>Ubicación</h3>
						<p>Pendiente de confirmar</p>
					</div>

					<div>
						<h3>Horario</h3>
						<p>Pendiente de confirmar</p>
					</div>
				</div>
			</div>

			<form class="contact-form" aria-label="Formulario de contacto">
                {propertySlug && (
                    <div class="property-form-notice form-field-full">
                        <p class="eyebrow">Consulta sobre inmueble</p>
                        <p>
                            Has llegado desde una ficha de inmueble. Incluiremos esta referencia en
                            tu consulta para que la asesoría pueda identificarla correctamente.
                        </p>
                        <input type="hidden" name="propertySlug" value={propertySlug} />
                    </div>
                )}
				<div class="form-field">
					<label for="name">Nombre y apellidos *</label>
					<input
						id="name"
						name="name"
						type="text"
						autocomplete="name"
						required
						placeholder="Tu nombre"
					/>
				</div>

				<div class="form-field">
					<label for="email">Email *</label>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						required
						placeholder="tu@email.com"
					/>
				</div>

				<div class="form-field">
					<label for="phone">Teléfono</label>
					<input
						id="phone"
						name="phone"
						type="tel"
						autocomplete="tel"
						placeholder="Tu teléfono"
					/>
				</div>

				<div class="form-field">
					<label for="subject">Tipo de consulta *</label>
					<select id="subject" name="subject" required>
						<option value="">Selecciona una opción</option>
						<option value="asesoria-fiscal">Asesoría fiscal</option>
						<option value="asesoria-contable">Asesoría contable</option>
						<option value="asesoria-laboral">Asesoría laboral</option>
						<option value="gestion-administrativa">Gestión administrativa</option>
						<option value="inmobiliaria" selected={Boolean(propertySlug)}>Inmobiliaria</option>
						<option value="otra-consulta">Otra consulta</option>
					</select>
				</div>

				<div class="form-field form-field-full">
					<label for="message">Mensaje *</label>
					<textarea
						id="message"
						name="message"
						rows="6"
						required
						placeholder="Cuéntanos brevemente qué necesitas"
					></textarea>
				</div>

				<label class="privacy-check form-field-full">
					<input type="checkbox" name="privacy" required />
					<span>
						He leído y acepto la política de privacidad. Texto legal pendiente de
						revisión profesional.
					</span>
				</label>

				<p class="form-note form-field-full">
					Este formulario todavía no envía mensajes. En el siguiente paso
					decidiremos la integración más adecuada para hacerlo funcional.
				</p>

				<div class="form-actions form-field-full">
					<button class="button button-primary" type="submit">
						Enviar consulta
					</button>
				</div>
			</form>
		</div>
	</section>
</BaseLayout>