---
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

const currentPath = Astro.url.pathname;

const isActivePath = (path: string) => {
	if (path === "/") {
		return currentPath === "/";
	}

	return currentPath.startsWith(path);
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<title>{title}</title>
	</head>

	<body>
		<a class="skip-link" href="#main-content">Saltar al contenido principal</a>

		<header class="site-header">
			<div class="container header-content">
				<a class="logo" href="/" aria-label="d’Papeleos Asesores">
					<img
						src="/dpapeleos.png"
						alt="d’Papeleos Asesores"
						class="logo-image"
					/>
				</a>

				<nav class="main-nav" aria-label="Navegación principal">
					<a
						href="/"
						class:list={{ "is-active": isActivePath("/") }}
						aria-current={isActivePath("/") ? "page" : undefined}
					>
						Inicio
					</a>
					<a
						href="/servicios"
						class:list={{ "is-active": isActivePath("/servicios") }}
						aria-current={isActivePath("/servicios") ? "page" : undefined}
					>
						Servicios
					</a>
					<a
						href="/inmobiliaria"
						class:list={{ "is-active": isActivePath("/inmobiliaria") }}
						aria-current={isActivePath("/inmobiliaria") ? "page" : undefined}
					>
						Inmobiliaria
					</a>
					<a
						href="/sobre-nosotros"
						class:list={{ "is-active": isActivePath("/sobre-nosotros") }}
						aria-current={isActivePath("/sobre-nosotros") ? "page" : undefined}
					>
						Sobre nosotros
					</a>
					<a
						href="/contacto"
						class:list={{ "is-active": isActivePath("/contacto") }}
						aria-current={isActivePath("/contacto") ? "page" : undefined}
					>
						Contacto
					</a>
				</nav>
			</div>
		</header>

		<main id="main-content">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container footer-grid">
				<div>
					<a class="footer-logo" href="/" aria-label="d’Papeleos Asesores">
						d’Papeleos Asesores
					</a>
					<p>
						Asesoría y gestoría para particulares, autónomos y empresas, con
						servicios de trámites, asesoramiento e inmobiliaria.
					</p>
				</div>

				<div>
					<h2>Secciones</h2>
					<nav class="footer-nav" aria-label="Navegación secundaria">
						<a href="/">Inicio</a>
						<a href="/servicios">Servicios</a>
						<a href="/inmobiliaria">Inmobiliaria</a>
						<a href="/sobre-nosotros">Sobre nosotros</a>
						<a href="/contacto">Contacto</a>
					</nav>
				</div>

				<div>
					<h2>Contacto</h2>
					<p>
						Avenida de la Constitución 19<br />
						San Isidro de Níjar, Almería
					</p>
					<p class="footer-contact-note">
						<a href="tel:+34685554865">+34 685 55 48 65</a><br />
						<a href="mailto:depapeleos@gmail.com">depapeleos@gmail.com</a>
					</p>
					<p class="footer-contact-note">
						Lunes a viernes, de 9:30 h a 13:45 h.<br />
						Tardes solo con cita previa.
					</p>
					<a class="footer-cta" href="/contacto">Ver datos de contacto</a>
				</div>
			</div>

			<div class="container footer-bottom">
				<p>© 2026 d’Papeleos. Todos los derechos reservados.</p>
				<p>Textos legales pendientes de revisión y validación antes de publicar.</p>
			</div>
		</footer>
	</body>
</html>